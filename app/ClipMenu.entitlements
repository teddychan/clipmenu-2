<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Developer ID / Homebrew (direct, non-sandboxed) build entitlements.

  No App Sandbox key: the direct build is unsandboxed, so it can auto-paste AND
  read/write the user's chosen backup folder (in Dropbox / iCloud Drive / Google
  Drive) with no extra entitlement.

  No iCloud entitlements: sync and backup are folder-based (see FolderBackupStore /
  SettingsSidecar), which require no iCloud container, CloudKit, or KV-store
  entitlement. __TEAM_ID__ is substituted at sign time.
-->
<plist version="1.0">
<dict>
	<key>com.apple.application-identifier</key>
	<string>__TEAM_ID__.com.dragonapp.clipmenu-2</string>
	<key>com.apple.developer.team-identifier</key>
	<string>__TEAM_ID__</string>
</dict>
</plist>
